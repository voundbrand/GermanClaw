{
  "name": "@openclaw/voice-call",
  "version": "2026.3.26",
  "description": "OpenClaw voice-call plugin",
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --target=node22 --external:openclaw --external:openclaw/* --outfile=dist/index.js"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "commander": "^14.0.3",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.26"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "minHostVersion": ">=2026.3.26"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
